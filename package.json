{
  "name": "email-finder",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm --recursive --parallel --if-present run dev",
    "build": "pnpm --recursive --if-present run build",
    "check-types": "pnpm --recursive --if-present run check-types",
    "dev:web": "pnpm --filter web run dev:bare",
    "deploy": "echo 'Deployment disabled: SMTP mailbox checks are intentionally local-development only.'",
    "destroy": "pnpm --filter @email-finder/infra run destroy"
  },
  "dependencies": {
    "@email-finder/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@email-finder/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.13.1"
}
